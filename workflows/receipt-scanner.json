    {
      "parameters": {
        "jsCode": "// Parse AI response JSON\nlet raw = $json.output ?? '';\nif (typeof raw !== 'string') raw = JSON.stringify(raw);\nraw = raw.replace(/^```(?:json)?\\s*/i, '').replace(/\\s*```\\s*$/, '').trim();\nconst jsonMatch = raw.match(/\\{[\\s\\S]*\\}/);\nif (!jsonMatch) throw new Error('No JSON found in AI response: ' + raw.substring(0, 200));\nconst data = JSON.parse(jsonMatch[0]);\n\n// Allowed categories for validation\nconst VALID_CATEGORIES = [\n  'Food & Dining', 'Groceries', 'Gas & Fuel', 'Office Supplies',\n  'Travel & Lodging', 'Utilities', 'Medical & Health', 'Entertainment',\n  'Shopping', 'Transportation', 'Subscriptions', 'Home & Garden',\n  'Auto & Maintenance', 'Personal Care', 'Education', 'Other'\n];\n\n// Validate / fix category\nif (!data.category || !VALID_CATEGORIES.includes(data.category)) {\n  const cat = (data.category || '').toLowerCase();\n  const match = VALID_CATEGORIES.find(c => cat.includes(c.split(' ')[0].toLowerCase()));\n  data.category = match || 'Other';\n}\n\n// If AI returned items as an array, convert to readable string\nif (Array.isArray(data.items)) {\n  data.items = data.items.map(item => {\n    if (typeof item === 'string') return item;\n    const name = item.name || item.description || item.item || 'Item';\n    const price = item.total_price || item.unit_price || item.price || item.amount;\n    return price != null ? `${name} $${price}` : name;\n  }).join(' \\u00b7 ');\n} else if (data.line_items) {\n  const li = Array.isArray(data.line_items) ? data.line_items : [];\n  data.items = li.map(item => {\n    if (typeof item === 'string') return item;\n    const name = item.name || item.description || item.item || 'Item';\n    const price = item.total_price || item.unit_price || item.price || item.amount;\n    return price != null ? `${name} $${price}` : name;\n  }).join(' \\u00b7 ');\n  delete data.line_items;\n}\n\n// Map internal field names to EXACT sheet column headers\nconst FIELD_MAP = {\n  'document_type': null,\n  'date': 'Date',\n  'vendor': 'Vendor',\n  'category': 'Category',\n  'total': 'Total',\n  'subtotal': 'Subtotal',\n  'tax': 'Tax',\n  'tip': 'Tip',\n  'payment_method': 'Payment Method',\n  'description': 'Description',\n  'items': 'Items',\n  'address': 'Address',\n  'receipt_number': 'Receipt #',\n  'invoice_number': 'Invoice #',\n  'due_date': 'Due Date',\n  'billed_to': 'Billed To'\n};\n\nconst row = {};\n// Keep document_type as-is for the Receipt or Invoice? routing node\nrow.document_type = data.document_type || 'receipt';\nfor (const [field, header] of Object.entries(FIELD_MAP)) {\n  if (!header) continue;\n  if (data[field] !== undefined && data[field] !== null && data[field] !== '') {\n    row[header] = data[field];\n  }\n}\n\nreturn [{ json: row }];"
      },
