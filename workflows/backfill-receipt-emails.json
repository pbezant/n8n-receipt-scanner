    {
      "parameters": {
        "jsCode": "\nconst metaItems = $('Has File Attachment?').all();\nconst results = [];\n\nfor (let i = 0; i < $input.all().length; i++) {\n  const downloadItem = $input.all()[i];\n  const meta = (metaItems[i] || {}).json || {};\n\n  const base64url = downloadItem.json.data;\n  const filename = meta.filename || 'attachment.bin';\n  const mimeType = meta.mimeType || 'application/octet-stream';\n\n  const base64 = base64url.replace(/-/g, '+').replace(/_/g, '/');\n  const buffer = Buffer.from(base64, 'base64');\n\n  results.push({\n    json: { fileName: filename },\n    binary: {\n      attachment_0: await this.helpers.prepareBinaryData(buffer, filename, mimeType)\n    }\n  });\n}\n\nreturn results;\n"
      },
      "id": "j7k8l9m0-n1o2-3456-j345-789abcdef012",
