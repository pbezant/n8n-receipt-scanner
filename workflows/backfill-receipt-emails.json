    {
      "parameters": {
        "jsCode": "\nfunction findInParts(parts, messageId) {\n  const result = { files: [], htmlBody: null };\n  if (!parts) return result;\n  for (const part of parts) {\n    if (part.body && part.body.attachmentId && part.filename) {\n      result.files.push({\n        type: 'attachment',\n        messageId,\n        attachmentId: part.body.attachmentId,\n        filename: part.filename,\n        mimeType: part.mimeType || 'application/octet-stream'\n      });\n    } else if (part.mimeType === 'text/html' && part.body && part.body.data && !result.htmlBody) {\n      result.htmlBody = part.body.data;\n    }\n    if (part.parts) {\n      const sub = findInParts(part.parts, messageId);\n      result.files.push(...sub.files);\n      if (!result.htmlBody) result.htmlBody = sub.htmlBody;\n    }\n  }\n  return result;\n}\n\nconst results = [];\n\nfor (const item of $input.all()) {\n  const message = item.json;\n  const { files, htmlBody } = findInParts(message.payload && message.payload.parts, message.id);\n\n  const topLevel = message.payload || {};\n  const topLevelHtml = (topLevel.mimeType === 'text/html' && topLevel.body && topLevel.body.data)\n    ? topLevel.body.data : null;\n  const htmlData = htmlBody || topLevelHtml;\n\n  if (files.length > 0) {\n    results.push(...files.map(f => ({ json: f })));\n  } else if (htmlData) {\n    const subject = message.Subject || ('receipt-' + message.id);\n    const filename = subject.replace(/[^a-zA-Z0-9\\s\\-_]/g, '').trim().replace(/\\s+/g, '-').substring(0, 80) + '.html';\n    results.push({ json: { type: 'html', messageId: message.id, filename, mimeType: 'text/html', htmlData } });\n  }\n}\n\nreturn results;\n"
      },
