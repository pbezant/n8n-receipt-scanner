      "parameters": {
        "jsCode": "\nconst results = [];\n\nfor (const item of $input.all()) {\n  const htmlData = item.json.htmlData;\n  const filename = item.json.filename;\n  const base64 = htmlData.replace(/-/g, '+').replace(/_/g, '/');\n  const buffer = Buffer.from(base64, 'base64');\n  results.push({\n    json: { fileName: filename },\n    binary: {\n      attachment_0: await this.helpers.prepareBinaryData(buffer, filename, 'text/html')\n    }\n  });\n}\n\nreturn results;\n"
